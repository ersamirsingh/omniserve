# ==========================================
# OmniServe Backend Environment Configuration
# ==========================================

# Application Settings
NODE_ENV=development
PORT=5000

# Client App URL (For CORS and redirect links)
CLIENT_URL=http://localhost:5173

# Database & Cache Settings
MONGO_URI=mongodb://localhost:27017/omniserve
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_USERNAME=
REDIS_PASSWORD=

# Authentication Secrets
JWT_SECRET=your_jwt_access_secret_key_change_in_production
JWT_EXPIRY=15m
JWT_REFRESH_SECRET=your_jwt_refresh_secret_key_change_in_production
JWT_REFRESH_EXPIRY=7d
RESTAURANT_JOIN_INVITE_EXPIRY_DAYS=7

# Email Service (SMTP)
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=your_smtp_username
SMTP_PASS=your_smtp_password

# Payment Gateways (Razorpay / Stripe)
RAZORPAY_KEY_ID=rzp_test_yourKeyId
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret
STRIPE_SECRET_KEY=sk_test_yourStripeSecretKey
STRIPE_WEBHOOK_SECRET=whsec_yourStripeWebhookSecret

# AI & Vector Database (Qdrant & Neo4j)
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL_NAME=gemini-1.5-flash
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=omniserve_unstructured
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password

# Outbound Webhook Security
WEBHOOK_SECRET=whsec_your_webhooks_secret
