{
  "name": "food-ordering-backend",
  "version": "1.0.0",
  "description": "Multi-tenant Food Ordering Platform Backend",
  "private": true,
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "clean": "rm -rf dist",
    "seed": "tsx src/scripts/seed.ts",
    "test:dining": "tsx tests/e2e_dining_workflow.ts",
    "test:acceptance": "tsx tests/acceptance/guest/guest-flow.test.ts && tsx tests/acceptance/online/online-flow.test.ts && tsx tests/acceptance/guest/phase9-features.test.ts",
    "test": "npm run test:acceptance"
  },
  "keywords": [
    "nodejs",
    "typescript",
    "express",
    "mongodb",
    "mongoose",
    "redis"
  ],
  "author": "Samir Singh",
  "license": "ISC",
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@qdrant/js-client-rest": "^1.18.0",
    "@socket.io/redis-adapter": "^8.3.0",
    "bcrypt": "^6.0.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.1.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.18.1",
    "neo4j-driver": "^6.2.0",
    "nodemailer": "^9.0.1",
    "razorpay": "^2.9.6",
    "redis": "^5.12.1",
    "socket.io": "^4.8.3",
    "stripe": "^22.3.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.10",
    "@types/node": "^24.3.1",
    "@types/nodemailer": "^8.0.1",
    "@types/redis": "^4.0.11",
    "socket.io-client": "^4.8.3",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2"
  }
}
