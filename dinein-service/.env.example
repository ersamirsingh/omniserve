# FoodMesh DineIn Service - Environment Variables
# Copy to .env and fill in your values

# ============================
# Server
# ============================
NODE_ENV=development
PORT=5100
CLIENT_URL=http://localhost:5173

# ============================
# MongoDB (same cluster as main server)
# ============================
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/foodmesh-dinein?retryWrites=true&w=majority

# ============================
# Redis (same instance as main server)
# ============================
REDIS_HOST=your-redis-host
REDIS_PORT=6379
REDIS_PASSWORD=your-redis-password
REDIS_USERNAME=default

# ============================
# JWT (share same secret as main server for cross-service token verification)
# ============================
JWT_SECRET=your-jwt-secret-must-match-main-server
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ============================
# QR Session
# ============================
QR_SECRET=your-qr-hmac-secret
QR_SESSION_TTL_MINUTES=120

# ============================
# CORS
# ============================
DINEIN_CONSOLE_URL=http://localhost:5173
MAIN_CLIENT_URL=http://localhost:5174

# ============================
# Rate Limiting
# ============================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ============================
# Logging
# ============================
LOG_LEVEL=info
LOG_DIR=./logs

# ============================
# Socket.io
# ============================
SOCKET_CORS_ORIGIN=http://localhost:5173
